warding consistent performance. The top 10% of funds in each category receive five stars, the next 22.5% receive four stars, the next 35% receive three stars, the next 22.5% receive two stars and the bottom 10% receive one star. (Each share class is counted as a fraction of one fund within this scale and rated separately, which may cause slight variations in the distribution percentages.) The Overall Morningstar Rating for a fund is derived from a weighted-average of the performance figures associated with its 3-, 5- and 10-year (if applicable) Morningstar Rating metrics.&lt;br /&gt;&lt;br /&gt;Morningstar Ratings are for the share classes cited only; other classes may have different ratings.","prefix":null,"value":"3","returnType":false,"associatedReturnType":false,"fullName":"fundHeader.fundNav.mstarRatingOverall"},"navAmount":{"name":"navAmount","visible":true,"active":true,"asOf":false,"hideNullData":false,"mobileEnabled":false,"sortOrder":2,"asOfDate":20260714,"formattedAsOfDate":"Jul 14, 2026","formattedValue":"294.47","label":"","asOfLabel":"NAV as of","infoBubble":"","prefix":"$","value":294.473473,"returnType":false,"associatedReturnType":false,"fullName":"fundHeader.fundNav.navAmount"},"navAmountChange":{"name":"navAmountChange","visible":true,"active":true,"asOf":false,"hideNullData":false,"mobileEnabled":false,"sortOrder":4,"asOfDate":20260714,"formattedAsOfDate":"Jul 14, 2026","formattedValue":"1.15","label":"","asOfLabel":"1 Day NAV Change as of","infoBubble":"","prefix":"$","value":1.145728,"returnType":false,"associatedReturnType":false,"fullName":"fundHeader.fundNav.navAmountChange"},"percentChange":{"name":"percentChange","visible":false,"active":true,"asOf":false,"hideNullData":false,"mobileEnabled":false,"sortOrder":null,"asOfDate":null,"formattedAsOfDate":null,"formattedValue":"0.39","label":"","asOfLabel":"","infoBubble":"","prefix":null,"value":0.39059653221688934,"returnType":false,"associatedReturnType":false,"fullName":"fundHeader.fundNav.p