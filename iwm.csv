.riskprofile.higherrisk":[{"metadata":null,"text":"Higher Risk/Reward"}],"label.riskprofile.lowerrisk":[{"metadata":null,"text":"Lower Risk/Reward"}],"label.riskprofile.potentialhigherrewards":[{"metadata":null,"text":"Potentially Higher Rewards"}],"label.sector_level_summary.sector":[{"metadata":null,"text":"Sector"}],"label.sector_level_summary.sub_sector":[{"metadata":null,"text":"Sub-sector"}],"label.short":[{"metadata":null,"text":"Short"}],"label.top_bonds.corporate_bonds":[{"metadata":null,"text":"Top 5 Corporate Bonds"}],"label.top_bonds.coupon":[{"metadata":null,"text":"Coupon"}],"label.top_bonds.credit_rating":[{"metadata":null,"text":"Credit Rating"}],"label.top_bonds.government_bonds":[{"metadata":null,"text":"Top 5 Government Bonds"}],"label.top_bonds.industry_sector":[{"metadata":null,"text":"Industry Sector"}],"label.top_bonds.maturity_date":[{"metadata":null,"text":"Maturity Date"}],"label.top_bonds.weight":[{"metadata":null,"text":"Weight"}],"label.top_bonds.yield_to_maturity":[{"metadata":null,"text":"Yield to Maturity"}],"label.topholdings.totalofportfolio":[{"metadata":null,"text":"Total of Portfolio"}],"label.tradinginformation.cusip":[{"metadata":null,"text":"CUSIP"}],"label.tradinginformation.exchange":[{"metadata":null,"text":"Exchange"}],"label.tradinginformation.totalmarketcapinindex":[{"metadata":null,"text":"Total Index Market Cap"}],"label.unsubsidized30daysecyield":[{"metadata":null,"text":"Unsubsidized 30-Day SEC Yield"}],"label.us_credit_rating.moody":[{"metadata":null,"text":"Moody's"}],"label.us_credit_rating.rating":[{"metadata":null,"text":"Rating"}],"label.us_credit_rating.sp":[{"metadata":null,"text":"S&P"}],"label.yes":[{"metadata":null,"text":"Yes"}],"label.yielddata.distributionyield":[{"metadata":null,"text":"Distribution Yield"}],"label.yielddata.realyieldtomaturity":[{"metadata":null,"text":"Real Yield to Maturity"}],"label.yielddata.trailing12monthyield":[{"metadata":null,"text":"Trailing 12-month Yield"}],"morning_star_ratings.disclaimer":[{"metadata":null,"text":"Rated against fred.mstarFundsOverallData fred.mstarCategory Funds, as of 06/30/2025 based on risk adjusted total return. Overall Ratings are determined monthly and subject to change. The Overall Morningstar Rating for a fund is derived from a weighted average of the performance figures associated with its 3-, 5- and 10-year (if applicable) Morningstar Rating metrics.††"}],"morningstar-analyst-ratings-page2.disclaimer":[],"morningstar-star-rating-10-year-page2.disclaimer":[{"metadata":null,"text":"†† The Morningstar RatingTM for funds, or \"star rating\", is calculated for managed products (including mutual funds, variable annuity and variable life subaccounts, exchange-traded funds, closed-end funds, and separate accounts) with at least a three-year history. Exchange-traded funds and open-ended mutual funds are considered a single population for comparative purposes. It is calculated based on a Morningstar Risk-Adjusted Return measure (excluding any applicable sales charges) that accounts for variation in a managed product's monthly excess performance, placing more emphasis on downward variations and rewarding consistent performance. The top 10% of products in each product category receive 5 stars, the next 22.5% receive 4 stars, the next 35% receive 3 stars, the next 22.5% receive 2 stars, and the bottom 10% receive 1 star. The Overall Morningstar Rating for a managed product is derived from a weighted average of the performance figures associated with its three-, five-, and 10-year (if applicable) Morningstar Rating metrics. The weights are: 100% three-year rating for 36-59 months of total returns, 60% five-year rating/40% three-year rating for 60-119 months of total returns, and 50% 10-year rating/30% five-year rating/20% three-year rating for 120 or more months of total returns. While the 10-year overall star rating formula seems to give the most weight to the 10-year period, the most recent three-year period actually has the greatest impact because it is included in all three rating periods. The fund was rated against the following numbers of U.S.-domiciled fred.mstarCategory funds over the following time periods: fred.mstarFundsOverall3yr in the last 3 years, fred.mstarFundsOverall5yr in the last 5 years and fred.mstarFundsOverall10yr in the last 10 years. With respect to these fred.mstarCategory funds, the fund received a Morningstar Rating of fred.mstarRating3yr, fred.mstarRating5yr and fred.mstarRating10yr stars for the 3-, 5- and 10-year periods, respectively. Other classes may have different performance characteristics."}],"morningstar-star-rating-3-year-page2.disclaimer":[{"metadata":null,"text":"†† The Morningstar RatingTM for funds, or \"star rating\", is calculated for managed products (including mutual funds, variable annuity and variable life subaccounts, exchange-traded funds, closed-end funds, and separate accounts) with at least a three-year history. Exchange-traded funds and open-ended mutual funds are considered a single population for comparative purposes. It is calculated based on a Morningstar Risk-Adjusted Return measure (excluding any applicable sales charges) that accounts for variation in a managed product's monthly excess performance, placing more emphasis on downward variations and rewarding consistent performance. The top 10% of products in each product category receive 5 stars, the next 22.5% receive 4 stars, the next 35% receive 3 stars, the next 22.5% receive 2 stars, and the bottom 10% receive 1 star. The Overall Morningstar Rating for a managed product is derived from a weighted average of the performance figures associated with its three-, five-, and 10-year (if applicable) Morningstar Rating metrics. The weights are: 100% three-year rating for 36-59 months of total returns, 60% five-year rating/40% three-year rating for 60-119 months of total returns, and 50% 10-year rating/30% five-year rating/20% three-year rating for 120 or more months of total returns. While the 10-year overall star rating formula seems to give the most weight to the 10-year period, the most recent three-year period actually has the greatest impact because it is included in all three rating periods. The fund was rated against the following numbers of U.S.-domiciled fred.mstarCategory funds over the following time period: fred.mstarFundsOverall3yr in the last 3 years. With respect to these fred.mstarCategory funds, the fund received a Morningstar Rating of fred.mstarRating3yr stars for the 3-year period. Other classes may have different performance characteristics."}],"morningstar-star-rating-5-year-page2.disclaimer":[{"metadata":null,"text":"†† The Morningstar RatingTM for funds, or \"star rating\", is calculated for managed products (including mutual funds, variable annuity and variable life subaccounts, exchange-traded funds, closed-end funds, and separate accounts) with at least a three-year history. Exchange-traded funds and open-ended mutual funds are considered a single population for comparative purposes. It is calculated based on a Morningstar Risk-Adjusted Return measure (excluding any applicable sales charges) that accounts for variation in a managed product's monthly excess performance, placing more emphasis on downward variations and rewarding consistent performance. The top 10% of products in each product category receive 5 stars, the next 22.5% receive 4 stars, the next 35% receive 3 stars, the next 22.5% receive 2 stars, and the bottom 10% receive 1 star. The Overall Morningstar Rating for a managed product is derived from a weighted average of the performance figures associated with its three-, five-, and 10-year (if applicable) Morningstar Rating metrics. The weights are: 100% three-year rating for 36-59 months of total returns, 60% five-year rating/40% three-year rating for 60-119 months of total returns, and 50% 10-year rating/30% five-year rating/20% three-year rating for 120 or more months of total returns. While the 10-year overall star rating formula seems to give the most weight to the 10-year period, the most recent three-year period actually has the greatest impact because it is included in all three rating periods. The fund was rated against the following numbers of U.S.-domiciled fred.mstarCategory funds over the following time periods: fred.mstarFundsOverall3yr in the last 3 years and fred.mstarFundsOverall5yr in the last 5 years. With respect to these fred.mstarCategory funds, the fund received a Morningstar Rating of fred.mstarRating3yr and fred.mstarRating5yr stars for the 3-and 5-year periods, respectively. Other classes may have different performance characteristics."}],"performance-scenario.upper-disclaimer":[{"metadata":null,"text":"The EU Packaged Retail and Insurance-Based Products Regulation (PRIIPs) prescribes the calculation methodology, and publication of the outcomes, of four hypothetical performance scenarios regarding how the product may perform under certain conditions and for such to be published on a monthly basis. The figures shown include all the costs of the product itself, but may not include all the costs that you pay to your advisor or distributor. The figures do not take into account your personal tax situation, which may also affect how much you get back. What you will get from this product depends on future market performance. Market developments in the future are uncertain and cannot be accurately predicted. The unfavourable, moderate, and favourable scenarios shown are illustrations using the worst, average, and best performance of the product, which may include input from benchmark(s) / proxy, over the last ten years."}],"performance.chart.disclaimer":[{"metadata":null,"text":"The Hypothetical Growth of $10,000 chart reflects a hypothetical $10,000 investment and assumes reinvestment of dividends and capital gains. Fund expenses, including management fees and other expenses were deducted. <br /><br />The performance quoted represents past performance and does not guarantee future results. Investment return and principal value of an investment will fluctuate so that an investor’s shares, when sold or redeemed, may be worth more or less than the original cost. Current performance may be lower or higher than the performance quoted, and numbers may reflect small variances due to rounding. Standardized performance and performance data current to the most recent month end may be found in the Performance section. <br /><br />"}],"performance.disclaimer":[{"metadata":null,"text":"<strong>The performance quoted represents past performance and does not guarantee future results. Investment return and principal value of an investment will fluctuate so that an investor’s shares, when sold or redeemed, may be worth more or less than the original cost. Current performance may be lower or higher than the performance quoted. Performance data current to the most recent month end may be obtained by visiting <a href=\"http://www.iShares.com\">www.iShares.com</a> or <a href=\"http://www.blackrock.com\">www.blackrock.com</a>.</strong>"},{"metadata":null,"text":"Beginning 8/10/20, the market price returns are calculated using the closing price. <br />Prior to 8/10/20, the market price returns were calculated using the midpoint of the bid/ask spread at 4:00 PM ET. The returns shown do not represent the returns you would receive if you traded shares at other times."}],"performance.premium-discount-chart.disclaimer":[{"metadata":null,"text":"<p>Shareholders may pay more than NAV when buying fund shares and receive less than NAV when selling fund shares, because shares are bought and sold at current market prices. The performance quoted represents past performance and does not guarantee future results.</p>"}],"performance.returns.disclaimer":[{"metadata":null,"text":"<em>The performance quoted represents past performance and does not guarantee future results. Investment return and principal value of an investment will fluctuate so that an investor's shares, when sold or redeemed, may be worth more or less than the original cost. Current performance may be lower or higher than the performance quoted.</em>"}],"performance.systematic-fair-value.disclaimer":[{"metadata":null,"text":"The ETF total return may appear to diverge from the return of its benchmark. This may be due to the use of systematic fair value. <span><strong><a href=\"#disclaimerDialog\" data-modaltitle=\"Understanding Systematic Fair Value\" data-link-event=\"managers:test:Click here\">Click here for more information</a></strong></span>"}],"performance.systematic-fair-value.module":[{"metadata":null,"text":"<style>\n .nfvNavPerformance {\n    color: black !important;\n    font-weight: bold !important;\n}\n</style>\n<div id=\"systFairValueModule\">The ETF total return is based on the ETF’s net asset value, which uses systematic fair value to price certain foreign assets as of 4:00 p.m. Eastern time (when foreign markets may be closed). The benchmark return uses local market closing prices which may differ from systematic fair value prices. This difference may result in divergence of ETF total return and benchmark return. For more information, please consult the fund’s prospectus. <span><strong><a class=\"nfvNavPerformance\" href=\"https://www.ishares.com/us/library?keyword=nfvnavperformance\" target=\"_blank\" rel=\"noopener\">Institutional Non-Fair Value Impact Report</a></strong></span>\n</div>\n"}],"portfolio_characteristics.disclaimer":[{"metadata":null,"text":"<strong>Beta</strong> is a measure of the tendency of securities to move with the market as a whole. A beta of 1 indicates that the security’s price will move with the market.  A beta less than 1 indicates the security tends to be less volatile than the market, while a beta greater than 1 indicates the security is more volatile than the market."},{"metadata":null,"text":"<strong>The price to earnings ratio (P/E)</strong> is a fundamental measure used to determine if an investment is valued appropriately. Each holding's P/E is the latest closing price divided by the latest fiscal year's earnings per share. Negative P/E ratios are excluded from this calculation. For hedged funds, the underlying fund’s value is shown."},{"metadata":null,"text":"<strong>The price to book (P/B)</strong> value ratio is a fundamental measure used to determine if an investment is valued appropriately. The book value of a company is a measure of how much a company's assets are worth assuming the company's debts are paid off. Each holding's P/B is the latest closing price divided by the latest fiscal year's book value per share. Negative book values are excluded from this calculation. For hedged funds, the underlying fund’s value is shown."}],"portfolio_management":[{"metadata":null,"text":"iShares ETFs are managed by investment professionals who have experience operating funds in all types of market environments. The Portfolio Management Team continually balances a variety of trade-offs in attempting to meet each fund’s investment objective and maximize tax efficiency."}],"pphero.exposures.disclaimer":[{"metadata":null,"text":"<p class=\"disclaimer-source\">Disclaimer</p>\n<p>Allocations are subject to change</p>"}],"pphero.exposures.story":[{"metadata":null,"text":"When you buy IVV, you're buying shares (or stocks) of exposure to the S&amp;P 500, and getting broad market access to hundreds of the largest companies in the U.S. This diversified fund can be used as a foundational holding in your portfolio to seek long-term growth over time."}],"pphero.exposures.tagline":[{"metadata":null,"text":"A focus on broad exposure"}],"pphero.fees.bulletpoints":[{"metadata":null,"text":"<ul>\n<li>\n<span class=\"data\">500</span><span class=\"label\">of the largest U.S. stocks.</span>\n</li>\n<li>\n<span class=\"data\">100&#43;</span><span class=\"label\">investment professionals including portfolio engineers, traders and researchers.</span>\n</li>\n</ul>\n<p style=\"text-align:left\">*Data as of March 31, 2019</p>"}],"pphero.fees.story":[{"metadata":null,"text":"The short answer is yes — but there’s good news. For exchange traded funds (ETFs) like IVV, the costs are low compared to mutual funds.  The very small amount you do pay in fees is used to help manage your investment: from the basics to the big stuff such as our powerful <a href=\"https://www.blackrock.com/aladdin\" target=\"_blank\" class=\"aladdin-link\">Aladdin</a> investment platform, intensive, proprietary research, and some of the most experienced teams in the industry."}],"pphero.fees.tagline":[{"metadata":null,"text":"Does it really take money to make money?"}],"pphero.fund-header.tagline":[{"metadata":null,"text":"Exposure to American companies"}],"pphero.fundheader.description":[{"metadata":null,"text":"The iShares Core S&amp;P 500 ETF (Ticker: IVV) provides low cost, tax efficient access to the S&amp;P 500 Index. The S&amp;P 500 contains some of the largest and most well-known U.S.-based companies across a variety of industries."}],"pphero.hypothetical.disclaimer":[{"metadata":null,"text":"<p class=\"disclaimer-source\" style=\"font-size: 14px;\">Source</p>\n\n<p style=\"font-family: BLKFortItalic; font-size: 14px; line-height: 17px;\">The chart reflects a hypothetical investment and assumes reinvestment of dividends and capital gains. Fund expenses, including management fees and other expenses were deducted.</p>\n\n<p style=\"font-family: BLKFortItalic; font-size: 14px; line-height: 17px;\">The performance quoted represents past performance and does not guarantee future results. Investment return and principal value of an investment will fluctuate so that an investor’s shares, when sold or redeemed, may be worth more or less than the original cost. Current performance may be lower or higher than the performance quoted, and numbers may reflect small variances due to rounding. For standardized performance and performance data current to the most recent month end, please click on the product ticker to view full fund details.</p>"}],"pphero.hypothetical.tagline":[{"metadata":null,"text":"<span>Curious how an investment could have grown?</span>"}],"pphero.nextsteps.disclaimer":[{"metadata":null,"text":"<p class=\"disclaimer-source\">Disclaimer</p>\n<p class=\"emphasis\">Carefully consider the Funds' investment objectives, risk factors, and charges and expenses before investing. This and other information can be found in the Funds' prospectuses or, if available, the summary prospectuses, which may be obtained by visiting the iShares ETF and BlackRock Fund prospectus pages. Read the prospectus carefully before investing. Investing involves risk, including possible loss of principal.</p>\n<br />\n<p class=\"italic\"><span>Before engaging Fidelity or any broker-dealer, you should evaluate the overall fees and charges of the firm as well as the services provided. Free commission offer applies to online purchases of select iShares ETFs in a Fidelity account. The sale of ETFs is subject to an activity assessment fee (from $0.01 to $0.03 per $1,000 of principal). For iShares ETFs, Fidelity receives compensation from the ETF sponsor and/or its affiliates in connection with an exclusive long-term marketing program that includes promotion of iShares ETFs and inclusion of iShares funds in certain Fidelity Brokerage Services platforms and investment programs. Please note, this security will not be marginable for 30 days from the settlement date, at which time it will automatically become eligible for margin collateral. Additional information about the sources, amounts, and terms of compensation can be found in the ETF’s prospectus and related documents. Fidelity may add or waive commissions on ETFs without prior notice.</span></p>\n<br />\n<p>This information should not be relied upon as research, investment advice, or a recommendation regarding any products, strategies, or any security in particular. This material is strictly for illustrative, educational, or informational purposes and is subject to change.</p>\n<br />\n<p>The Funds are distributed by BlackRock Investments, LLC (together with its affiliates, “BlackRock”).</p>\n<br />\n<p>©2019 BlackRock, Inc. All rights reserved. BLACKROCK, BLACKROCK SOLUTIONS, BUILD ON BLACKROCK, ALADDIN, iSHARES, iBONDS, iTHINKING, iSHARES CONNECT, FUND FRENZY, LIFEPATH, SO WHAT DO I DO WITH MY MONEY, INVESTING FOR A NEW WORLD, BUILT FOR THESE TIMES, the iShares Core Graphic, CoRI and the CoRI logo are registered and unregistered trademarks of BlackRock, Inc., or its subsidiaries in the United States and elsewhere. All other marks are the property of their respective owners.</p>"}],"pphero.nextsteps.email.story":[{"metadata":null,"text":"This fund may be an excellent addition to an investment portfolio. Before investing, it's always a good idea to check with your financial advisor to be sure that you are meeting your financial goals."}],"pphero.nextsteps.email.tagline":[{"metadata":null,"text":"<p>Start the Conversation</p>"}],"pphero.nextsteps.fidelity.story":[{"metadata":null,"text":"<p>The fund is available commission-free at Fidelity.</p>"}],"pphero.nextsteps.fidelity.tagline":[{"metadata":null,"text":"<p>Ready to Buy?</p>"}],"pphero.nextsteps.learn-more":[{"metadata":null,"text":"<p>If you're still learning about this fund, download the fact sheet or visit the fund page.</p>"}],"pphero.overview.tagline":[{"metadata":null,"text":"Is This Fund a Good Fit?"}],"priips-annual-cost-impact-rhp-less-than-1.text":[{"metadata":null,"text":"Cost impact (*)"}],"priips-annual-cost-impact-rhp-more-than-1.text":[{"metadata":null,"text":"Annual cost Impact (*)"}],"priips-average-return-year.text":[{"metadata":null,"text":"Average return each year"}],"priips-complaint.header":[{"metadata":null,"text":"How can I complain?"}],"priips-complaint.text":[{"metadata":null,"text":"If you are not entirely satisfied with any aspect of the service you have received and you wish to complain, details of our complaints handling process are available at www.blackrock.com/uk/individual/about-blackrock/contact-us. Additionally, you can also write to the Investor Services Team, at BlackRock’s UK Registered Office, 12 Throgmorton Avenue, London, EC2N 2DL or e-mail them at enquiry@ukclientservices.blackrock.com."}],"priips-composition-of-cost-header.text":[{"metadata":null,"text":"The table below shows:"}],"priips-composition-of-costs-footer-astersik-1.text":[{"metadata":null,"text":"Please refer to the person selling you or advising you about this product for the actual charges."}],"priips-composition-of-costs-footer-astersik-2.text":[{"metadata":null,"text":"This figure is based on estimated costs, often referencing historic data, and therefore the actual costs paid by an investor may differ."}],"priips-composition-of-costs-footer-header.text":[{"metadata":null,"text":"This table shows the impact each year of the different types of costs on the investment return you might get at the end of the recommended holding period and the meaning of the different cost categories."}],"priips-composition-of-costs-header-subtitle.text":[{"metadata":null,"text":"the impact each year of the different types of costs on the investment return you might get at the end of the recommended holding period."},{"metadata":null,"text":"the meaning of the different cost categories."}],"priips-composition-of-costs.disclaimer.text":[{"metadata":null,"text":"<sup>1</sup>Not applicable to secondary market investors. Investors dealing via stock exchanges will pay fees charged by stock brokers. Such charges can be obtained on exchanges where the shares are listed and traded, or from stock brokers. Authorised participants dealing directly with the Fund or the Management Company will pay related transaction costs."}],"priips-comprehension-alert.text":[{"metadata":null,"text":"<strong>Caution: You are about to purchase a product that is not simple and may be difficult to understand.</strong>"}],"priips-costs-over-time.text":[{"metadata":null,"text":"The person selling you or advising you about this product may charge you other costs. If so, this person will provide you with information about these costs, and show you the impact that all costs will have on your investment over time."}],"priips-costs.header":[{"metadata":null,"text":"What are the costs?"}],"priips-costs.text":[{"metadata":null,"text":"The person advising on or selling you this product may charge you other costs. If so, this person will provide you with information about these costs and how they affect your investment."}],"priips-favourable-scenario.label":[{"metadata":null,"text":"Favourable"}],"priips-header.text":[{"metadata":null,"text":"Key Information Document"}],"priips-if-you-exit-after-rhp.text":[{"metadata":null,"text":"If you exit after recommended holding period"}],"priips-if-you-exit-after.text":[{"metadata":null,"text":"If you exit after"}],"priips-intended-target-mkt-investor":[{"metadata":null,"text":"Retail and Professional Investors."}],"priips-investment.benchmark":[{"metadata":null,"text":"This type of scenario occurred for an investment in the product with input from benchmark(s) / proxy during"}],"priips-investment.disclaimer":[{"metadata":null,"text":"The stress scenario shows what you might get back in extreme market circumstances."},{"metadata":null,"text":"The figures shown include all the costs of the product itself, but may not include all the costs that you pay to your broker, financial adviser or distributor. The figures do not take into account your personal tax situation, which may also affect how much you get back."}],"priips-investment.label":[{"metadata":null,"text":"Example Investment"}],"priips-investment.label.ukpriip":[{"metadata":null,"text":"Investment"}],"priips-minimum.label":[{"metadata":null,"text":"Minimum"}],"priips-minimum.text":[{"metadata":null,"text":"There is no minimum guaranteed return. You could lose some or all of your investment."}],"priips-moderate-scenario.label":[{"metadata":null,"text":"Moderate"}],"priips-month.text":[{"metadata":null,"text":"month"}],"priips-months.text":[{"metadata":null,"text":"months"}],"priips-other-relevant-info.header":[{"metadata":null,"text":"Other relevant information"}],"priips-other-relevant-info.text":[{"metadata":null,"text":"The benchmark(s) referenced herein are the intellectual property of the index provider(s). The product is not sponsored or endorsed by the index provider(s). Please refer to the product’s prospectus and/or www.blackrock.com for full disclaimer(s)."},{"metadata":null,"text":"The Remuneration Policy of the Management Company, which describes how remuneration and benefits are determined and awarded, and the associated governance arrangements, is available at www.blackrock.com/Remunerationpolicy or on request from the registered office of the Manager."}],"priips-other-relevant-pastperformance-cat1.text":[{"metadata":null,"text":"The latest copy of this document, the Fund’s prospectus, the latest annual report and any additional information issued to investors can be obtained from your distributor."}],"priips-other-relevant-risk-narrative":[{"metadata":null,"text":"Refer to the UCITS KIID or PRIIPs KID for risk disclosures"}],"priips-presentation-of-costs.text":[{"metadata":null,"text":"The Reduction in Yield (RIY) shows what impact the total costs you pay will have on the investment return you might get. The total costs take into account one-off, ongoing and incidental costs."},{"metadata":null,"text":"The amounts shown here are the cumulative costs of the product itself, for one or more different holding periods. The figures assume you invest USD 10,000. The figures are estimates and may change in the future."}],"priips-product-details.header":[{"metadata":null,"text":"Product"}],"priips-product-details.text":[{"metadata":null,"text":"<strong>fred.fundProspectusName</strong> (the “Fund”), <strong>fred.investorClassCode fred.useOfProfit USD</strong> (the \"Unit Class\"/\"Share Class\"), ISIN: <strong>US4642876555</strong>"}],"priips-product-type.header":[{"metadata":null,"text":"What is this product?"}],"priips-product-type.insurance-benefits.label":[{"metadata":null,"text":"<strong>Insurance benefits:</strong>"}],"priips-product-type.insurance-benefits.text":[{"metadata":null,"text":"The Fund does not offer any insurance benefits."}],"priips-product-type.intended-retail-inv.label":[{"metadata":null,"text":"<strong>Intended retail investor:</strong>"}],"priips-product-type.objective.label":[{"metadata":null,"text":"Objectives"}],"priips-product-type.term.label":[{"metadata":null,"text":"<strong>Term:</strong>"}],"priips-product-type.type.label":[{"metadata":null,"text":"<strong>Type:</strong>"}],"priips-product-type.type.text":[{"metadata":null,"text":"Fund authorised as a UCITS product."}],"priips-proxy-disclaimer.text":[{"metadata":null,"text":"This type of scenario occurred for an investment in the product and/or benchmark(s) or proxy between :"}],"priips-proxy-favourable.text":[{"metadata":null,"text":"This type of scenario occurred for an investment in the product and/or benchmark(s) or proxy between"}],"priips-proxy-moderate.text":[{"metadata":null,"text":"This type of scenario occurred for an investment in the product and/or benchmark(s) or proxy between"}],"priips-proxy-unfavourable.text":[{"metadata":null,"text":"This type of scenario occurred for an investment in the product and/or benchmark(s) or proxy between"}],"priips-purpose.header":[{"metadata":null,"text":"Purpose"}],"priips-purpose.text":[{"metadata":null,"text":"This document provides you with key information about this investment product. It is not marketing material. The information is required by law to help you understand the nature, risks, costs, potential gains and losses of this product and to help you compare it with other products."}],"priips-relevant-risk-narrative-cat1-common":[{"metadata":null,"text":"The actual risk can vary significantly if you cash in at an early stage and you may get back less. You may not be able to cash in early. You may not be able to sell your product easily or you may have to sell at a price that significantly impacts on how much you get back."}],"priips-relevant-risk-narrative-common":[{"metadata":null,"text":"The actual risk can vary significantly if you cash in at an early stage and you may get back less."}],"priips-relevant-risk-narrative-rhp-in-month":[{"metadata":null,"text":"The risk indicator assumes you keep the product for 1 month."}],"priips-relevant-risk-narrative-rhp-in-months":[{"metadata":null,"text":"The risk indicator assumes you keep the product for <recommendedHoldingPeriod/> months."}],"priips-relevant-risk-narrative-rhp-less-than-1":[{"metadata":null,"text":"The risk indicator assumes you keep the product for <recommendedHoldingPeriod/> year."}],"priips-relevant-risk-narrative-rhp-more-than-1":[{"metadata":null,"text":"The risk indicator assumes you keep the product for <recommendedHoldingPeriod/> years."}],"priips-rhp-year.sub-text":[{"metadata":null,"text":"Recommended holding period"}],"priips-rhp.header":[{"metadata":null,"text":"How long should I hold it and can I take money out early?"}],"priips-rhp.sub-header":[{"metadata":null,"text":"Recommended Holding Period: <recommendedHoldingPeriod/>"}],"priips-rhp.text":[{"metadata":null,"text":"The recommended holding period (RHP) has been calculated in line with the investment strategy of the Fund and the time frame in which it is expected that it will be possible to achieve the investment objective of the Fund. Any investment should be considered against your specific investment needs and appetite for risk. BlackRock has not considered the suitability or appropriateness of this investment for your personal circumstances. If you are in any doubt about the suitability of the Fund to your needs you should seek appropriate professional advice. Details of dealing frequency can be found under “What is this product?”. You may receive less than expected if you cash in earlier than the RHP. The RHP is an estimate and must not be taken as a guarantee or an indication of future performance, return or risk levels. Please see the “What are the costs?” section for details of any exit fees."}],"priips-risk":[{"metadata":null,"text":"<strong>Be aware of currency risk.</strong> If you receive payments in a currency that is different to the product's base currency, the final return you will get depends on the exchange rate between the two currencies. This risk is not considered in the indicator shown above."},{"metadata":null,"text":"Please refer to the product's Prospectus for details of other materially relevant risks that may apply to this product."},{"metadata":null,"text":"This product does not include any protection from future market performance so you could lose some or all of your investment."},{"metadata":null,"text":"If the product is not able to pay you what is owed, you could lose your entire investment."}],"priips-risk-rewards.header":[{"metadata":null,"text":"What are the risks and what could I get in return?"}],"priips-risk-rewards.indicator-higher.label":[{"metadata":null,"text":"Higher risk"}],"priips-risk-rewards.indicator-lower.label":[{"metadata":null,"text":"Lower risk"}],"priips-risk-rewards.indicator.header":[{"metadata":null,"text":"Risk Indicator"}],"priips-risk-rewards.perf-scenario-cat2-not.text":[{"metadata":null,"text":"The scenarios shown are illustrations based on results from the past and on certain assumptions. Markets could develop very differently in the future. This product cannot be cashed in. This means it is difficult to estimate how much you would get back if you cash in before the end of the recommended holding period. You will either be unable to cash in early (or you will have to pay high costs) or make a large loss if you do so."}],"priips-risk-rewards.perf-scenario-cat2.text":[{"metadata":null,"text":"The unfavourable, moderate, and favourable scenarios shown are illustrations using the worst, average, and best performance of the product, which may include input from benchmark(s) / proxy, over the last ten years. Markets could develop very differently in the future."}],"priips-risk-rewards.perf-scenario-common-top.text":[{"metadata":null,"text":"The figures shown include all the costs of the product itself, but may not include all the costs that you pay to your advisor or distributor. The figures do not take into account your personal tax situation, which may also affect how much you get back. What you will get from this product depends on future market performance. Market developments in the future are uncertain and cannot be accurately predicted."}],"priips-risk-rewards.perf-scenario.header":[{"metadata":null,"text":"Performance Scenarios"}],"priips-risk-sri-1":[{"metadata":null,"text":"We have classified this product as 1 out of 7, which is the lowest risk class. This classification rates the potential losses from future performance at a very low level, and poor market conditions could affect the value of your investment. This classification is not guaranteed and may change over time and may not be a reliable indication of the future risk profile of the Fund. The lowest category does not mean risk free."}],"priips-risk-sri-2":[{"metadata":null,"text":"We have classified this product as 2 out of 7, which is a low risk class. This classification rates the potential losses from future performance at a low level, and poor market conditions could affect the value of your investment. This classification is not guaranteed and may change over time and may not be a reliable indication of the future risk profile of the Fund. The lowest category does not mean risk free."}],"priips-risk-sri-3":[{"metadata":null,"text":"We have classified this product as 3 out of 7, which is a medium low risk class. This classification rates the potential losses from future performance at a medium low level, and poor market conditions could affect the value of your investment. This classification is not guaranteed and may change over time and may not be a reliable indication of the future risk profile of the Fund. The lowest category does not mean risk free."}],"priips-risk-sri-4":[{"metadata":null,"text":"We have classified this product as 4 out of 7, which is a medium risk class. This classification rates the potential losses from future performance at a medium level, and poor market conditions could affect the value of your investment. This classification is not guaranteed and may change over time and may not be a reliable indication of the future risk profile of the Fund. The lowest category does not mean risk free."}],"priips-risk-sri-5":[{"metadata":null,"text":"We have classified this product as 5 out of 7, which is a medium high risk class. This classification rates the potential losses from future performance at a medium high level, and poor market conditions could affect the value of your investment. This classification is not guaranteed and may change over time and may not be a reliable indication of the future risk profile of the Fund. The lowest category does not mean risk free."}],"priips-risk-sri-6":[{"metadata":null,"text":"We have classified this product as 6 out of 7, which is the second highest risk class. This classification rates the potential losses from future performance at a high level, and poor market conditions could affect the value of your investment. This classification is not guaranteed and may change over time and may not be a reliable indication of the future risk profile of the Fund. The lowest category does not mean risk free."}],"priips-risk-sri-7":[{"metadata":null,"text":"We have classified this product as 7 out of 7, which is the highest risk class. This classification rates the potential losses from future performance at a very high level, and poor market conditions could affect the value of your investment. This classification is not guaranteed and may change over time and may not be a reliable indication of the future risk profile of the Fund. The lowest category does not mean risk free."}],"priips-risk-summary":[{"metadata":null,"text":"The summary risk indicator is a guide to the level of risk of this product compared to other products. It shows how likely it is that the product will lose money because of movements in the markets or because we are not able to pay you."}],"priips-scenario.label":[{"metadata":null,"text":"Scenarios"}],"priips-stress-scenario.label":[{"metadata":null,"text":"Stress"}],"priips-type-of-underlying-inv-option":[{"metadata":null,"text":"Fund is a UCITS or PRIIPs product."}],"priips-uk.perf-scenario-negative-return.header":[{"metadata":null,"text":"What could affect my return negatively?"}],"priips-uk.perf-scenario-positive-return.header":[{"metadata":null,"text":"What could affect my return positively?"}],"priips-uk.risk-rewards.perf-scenario.header":[{"metadata":null,"text":"Investment performance information"}],"priips-unfavourable-scenario.label":[{"metadata":null,"text":"Unfavourable"}],"priips-we-have-assumed-bottom-common-1.text":[{"metadata":null,"text":"We may share part of the costs with the person selling you the product to cover the services they provide to you. They will inform you of the amount."}],"priips-we-have-assumed-bottom-common-2.text":[{"metadata":null,"text":"These figures include the maximum distribution fee that the person selling you the product may charge (fred.frontCostPercent % of amount invested/ fred.frontCostAmt USD). This person will inform you of the actual distribution fee."}],"priips-we-have-assumed-bottom-rhp-less-than-1.text":[{"metadata":null,"text":"(*) This illustrates the effect of costs over a holding period of less than one year. This percentage cannot be directly compared to the cost impact figures provided for other PRIIPs."}],"priips-we-have-assumed-bottom-rhp-more-than-1.text":[{"metadata":null,"text":"(*) This illustrates how costs reduce your return each year over the holding period. For example it shows that if you exit at the recommended holding period your average return per year is projected to be fred.grossReturn% before costs and fred.longModerateFelBelAnn% after costs."}],"priips-we-have-assumed-top-currency.text":[{"metadata":null,"text":"USD fred.investmentAmount is invested."}],"priips-we-have-assumed-top-rhp-less-than-1.text":[{"metadata":null,"text":"You would get back the amount that you invested (0 % annual return)."}],"priips-we-have-assumed-top-rhp-more-than-1.text":[{"metadata":null,"text":"In the first year you would get back the amount that you invested (0 % annual return)."},{"metadata":null,"text":"For the other holding periods we have assumed the product performs as shown in the moderate scenario."}],"priips-what-you-might-get-back-after-cost":[{"metadata":null,"text":"What you might get back after costs"}],"priips-year.text":[{"metadata":null,"text":"year"}],"priips-years.text":[{"metadata":null,"text":"years"}],"priips.carried-interests":[{"metadata":null,"text":"Carried interests"}],"priips.carried-interests-alt.text":[{"metadata":null,"text":"There are no carried interests for this product."}],"priips.carried-interests.text":[{"metadata":null,"text":"The impact of the carried interests."}],"priips.composition-of-costs.header":[{"metadata":null,"text":"Composition of Costs"}],"priips.costs-over-time-rhp-less-than-1.text":[{"metadata":null,"text":"<strong>Costs over time:</strong> The tables show the amounts that are taken from your investment to cover different types of costs. These amounts depend on how much you invest and how long you hold the product. The amounts shown here are illustrations based on an example investment amount and different possible investment periods."}],"priips.costs-over-time-rhp-more-than-1.text":[{"metadata":null,"text":"<strong>Costs over time:</strong> The tables show the amounts that are taken from your investment to cover different types of costs. These amounts depend on how much you invest, how long you hold the product and how well the product does. The amounts shown here are illustrations based on an example investment amount and different possible investment periods."}],"priips.entry-costs":[{"metadata":null,"text":"Entry costs"}],"priips.entry-costs-alt.text-ukpriips":[{"metadata":null,"text":"We do not charge an entry fee.*"}],"priips.entry-costs-alternative.text":[{"metadata":null,"text":"We do not charge an entry fee.<sup>1</sup>"}],"priips.entry-costs.text":[{"metadata":null,"text":"of the amount you pay. This is the most you will be charged. The person selling you the product will inform you of the actual charge.<sup>1</sup>"}],"priips.entry-costs.text-ukpriips":[{"metadata":null,"text":"The impact of the costs you pay when entering your investment.*"}],"priips.exit-costs":[{"metadata":null,"text":"Exit costs"}],"priips.exit-costs-alt.text-ukpriips":[{"metadata":null,"text":"We do not charge an exit fee.*"}],"priips.exit-costs-alternative.text":[{"metadata":null,"text":"We do not charge an exit fee.<sup>1</sup>"}],"priips.exit-costs.text":[{"metadata":null,"text":"of your investment before it is paid out to you. This is the most you will be charged. The person selling you the product will inform you of the actual charge.<sup>1</sup>"}],"priips.exit-costs.text-ukpriips":[{"metadata":null,"text":"The impact of the costs of exiting your investment when it matures.*"}],"priips.if-you-cash-in-after.text":[{"metadata":null,"text":"If you cash in after"}],"priips.impact-on-return-year.text":[{"metadata":null,"text":"Impact on return (RIY) per year"}],"priips.incidental-costs":[{"metadata":null,"text":"Incidental costs taken under specific conditions"}],"priips.incidental-costs-ukpriips":[{"metadata":null,"text":"Incidental costs"}],"priips.mgmt-fee-and-other-costs":[{"metadata":null,"text":"Management fees and other administrative or operating costs"}],"priips.mgmt-fee-and-other-costs-alt.text":[{"metadata":null,"text":"of the value of your investment per year. This is based on estimated costs. Any underlying product costs are included here with the exception of transaction costs which would be included below under 'Transaction costs'."}],"priips.mgmt-fee-and-other-costs.text":[{"metadata":null,"text":"of the value of your investment per year. This is based on a combination of estimated and actual costs data over the last year. Any underlying product costs are included here with the exception of transaction costs which would be included below under 'Transaction costs'."}],"priips.month.april":[{"metadata":null,"text":"April"}],"priips.month.august":[{"metadata":null,"text":"August"}],"priips.month.december":[{"metadata":null,"text":"December"}],"priips.month.february":[{"metadata":null,"text":"February"}],"priips.month.january":[{"metadata":null,"text":"January"}],"priips.month.july":[{"metadata":null,"text":"July"}],"priips.month.june":[{"metadata":null,"text":"June"}],"priips.month.march":[{"metadata":null,"text":"March"}],"priips.month.may":[{"metadata":null,"text":"May"}],"priips.month.november":[{"metadata":null,"text":"November"}],"priips.month.october":[{"metadata":null,"text":"October"}],"priips.month.september":[{"metadata":null,"text":"September"}],"priips.one-off-costs":[{"metadata":null,"text":"One-off costs upon entry or exit"}],"priips.one-off-costs-ukpriips":[{"metadata":null,"text":"One-off costs"}],"priips.ongoing-costs":[{"metadata":null,"text":"Ongoing costs taken each year"}],"priips.ongoing-costs-ukpriips":[{"metadata":null,"text":"Ongoing costs"}],"priips.other-ongoing-costs":[{"metadata":null,"text":"Other ongoing costs"}],"priips.other-ongoing-costs.text":[{"metadata":null,"text":"The impact of the costs that we take each year for managing your investments. Any underlying product costs are included here with the exception of transaction costs which would be included above under 'Portfolio transaction costs'.**"}],"priips.performance-fee-carried-interest":[{"metadata":null,"text":"Performance fees"}],"priips.performance-fees-alt.text":[{"metadata":null,"text":"There is no performance fee for this product."}],"priips.total-cost.label":[{"metadata":null,"text":"Total costs"}],"priips.transaction-costs":[{"metadata":null,"text":"Transaction costs"}],"priips.transaction-costs-ukpriips":[{"metadata":null,"text":"Portfolio transaction costs"}],"priips.transaction-costs.text":[{"metadata":null,"text":"of the value of your investment per year. This is an estimate of the costs incurred when we buy and sell the underlying investments for the product. The actual amount will vary depending on how much we buy and sell."}],"priips.transaction-costs.text-ukpriips":[{"metadata":null,"text":"The impact of the costs of us buying and selling underlying investments for the product."}],"priips.we-have-assumed.header":[{"metadata":null,"text":"We have assumed:"}],"product-involvement.disclaimer":[{"metadata":null,"text":"<p>Business Involvement metrics are calculated by BlackRock using data from MSCI ESG Research which provides a profile of each company’s specific business involvement. BlackRock leverages this data to provide a summed up view across holdings and translates it to a fund's market value exposure to the listed Business Involvement areas above.</p>\n<br />\n<p><strong>Business Involvement metrics are designed only to identify companies where MSCI has conducted research and identified as having involvement in the covered activity. As a result, it is possible there is additional involvement in these covered activities where MSCI does not have coverage. This information should not be used to produce comprehensive lists of companies without involvement. Business Involvement metrics are only displayed if at least 1% of the fund’s gross weight includes securities covered by MSCI ESG Research.</strong></p>"}],"product-involvement.subtitle":[{"metadata":null,"text":"<p>Business Involvement metrics can help investors gain a more comprehensive view of specific activities in which a fund may be exposed through its investments.</p>\n<br />\n<p>Business Involvement metrics are not indicative of a fund’s investment objective, and, unless otherwise stated in fund documentation and included within a fund’s investment objective, do not change a fund’s investment objective or constrain the fund’s investable universe. For more information regarding a fund's investment strategy, please see the fund's prospectus.</p>\n<br />\n<p>Review the MSCI methodology behind the Business Involvement metrics, using links <strong><a href=\"#esg-footer\">below.</a></strong></p>"}],"product-literature.default":[{"metadata":null,"text":"{type=GLS;material=Product Brief}{type=GLS;material=Investor Guide}{type=GLS;material=Fact Sheet}{type=GLS;material=Prospectus}{type=GLS;material=Summary Prospectus}{type=GLS;material=Annual Report}{type=GLS;material=Semi-Annual Report}{type=GLS;material=Annual Financial Statements}{type=GLS;material=Semi-Annual Financial Statements}"}],"product-literature.gls-document-ids":[{"metadata":null,"text":"<p>2192026,947649</p>"}],"product-page.footer.disclaimer":[{"metadata":null,"text":"<p class=\"disclosure-16\"><strong>Carefully consider the Funds' investment objectives, risk factors, and charges and expenses before investing. This and other information can be found in the Funds' prospectuses or, if available, the summary prospectuses, which may be obtained by visiting the <a href=\"https://www.blackrock.com/us/individual/resources/regulatory-documents#etfs\" target=\"_blank\" rel=\"noopener\">iShares Fund</a> and <a href=\"https://www.blackrock.com/us/individual/resources/regulatory-documents#mutualfunds\" target=\"_blank\" title=\"BlackRock Fund\" rel=\"noopener\">BlackRock Fund</a> prospectus pages. Read the prospectus carefully before investing.</strong></p><br />"},{"metadata":null,"text":"<span style=\"font-size:15px\"><strong>Investing involves risk, including possible loss of principal.</strong></span>"},{"metadata":null,"text":"If the Fund invests in any underlying fund, certain portfolio information, including sustainability characteristics and business-involvement metrics, provided for the Fund may include information (on a look-through basis) of such underlying fund, to the extent available."},{"metadata":null,"text":"Small-capitalization companies may be less stable and more susceptible to adverse developments, and their securities may be more volatile and less liquid than larger capitalization companies."},{"metadata":null,"text":"Shares of ETFs are bought and sold at market price (not NAV) and are not individually redeemed from the fund. Any applicable brokerage commissions will reduce returns. Beginning August 10, 2020, market price returns for BlackRock and iShares ETFs are calculated using the closing price and account for distributions from the fund. Prior to August 10, 2020, market price returns for BlackRock and iShares ETFs were calculated using the midpoint price and accounted for distributions from the fund. The midpoint is the average of the bid/ask prices at 4:00 PM ET (when NAV is normally determined for most ETFs). The returns shown do not represent the returns you would receive if you traded shares at other times."},{"metadata":null,"text":"<strong>Index returns are for illustrative purposes only. Index performance returns do not reflect any management fees or expenses. Indexes are unmanaged and one cannot invest directly in an index. Past performance does not guarantee future results.</strong>"},{"metadata":null,"text":"After-tax returns are calculated using the historical highest individual federal marginal income tax rates and do not reflect the impact of state and local taxes. Actual after-tax returns depend on the investor's tax situation and may differ from those shown. The after-tax returns shown are not relevant to investors who hold their fund shares through tax-deferred arrangements such as 401(k) plans or individual retirement accounts."},{"metadata":null,"text":"Certain sectors and markets perform exceptionally well based on current market conditions and iShares and BlackRock Funds can benefit from that performance. Achieving such exceptional returns involves the risk of volatility and investors should not expect that such results will be repeated."},{"metadata":null,"text":"Distribution Yield and 12m Trailing Yield results may have period over period volatility due to factors including tax considerations such as treatment of passive foreign investment companies (PFICs), treatment of defaulted bonds or excise tax requirements; exceptional corporate actions; seasonality of dividends from underlying holdings; significant fluctuations in fund shares outstanding; or fund capital gain distributions."},{"metadata":null,"text":"The Funds are distributed by BlackRock Investments, LLC (together with its affiliates, “BlackRock”)."},{"metadata":null,"text":"<p class=\"disclaimer\">Although BlackRock shall obtain data from sources that BlackRock considers reliable, all data contained herein is provided “as is” and BlackRock makes no representation or warranty of any kind, either express or implied, with respect to such data, the timeliness thereof, the results to be obtained by the use thereof or any other matter. BlackRock expressly disclaims any and all implied warranties, including without limitation, warranties of originality, accuracy, completeness, timeliness, non-infringement, merchantability and fitness for a particular purpose.</p>"},{"metadata":null,"text":"BlackRock provides compensation in connection with obtaining or using third-party ratings and rankings."},{"metadata":null,"text":"<p class=\"disclaimer\">The iShares Funds are not sponsored, endorsed, issued, sold or promoted by Bloomberg, BlackRock Index Services, LLC, Cboe Global Indices, LLC, Cohen &amp; Steers, European Public Real Estate Association (“EPRA® ”), FTSE International Limited (“FTSE”), ICE Data Indices, LLC, NSE Indices Ltd, JPMorgan, JPX Group, London Stock Exchange Group (“LSEG”), MSCI Inc., Markit Indices Limited, Morningstar, Inc., Nasdaq, Inc., National Association of Real Estate Investment Trusts (“NAREIT”), Nikkei, Inc., Russell, S&amp;P Dow Jones Indices LLC or STOXX Ltd. None of these companies make any representation regarding the advisability of investing in the Funds. With the exception of BlackRock Index Services, LLC, who is an affiliate, BlackRock Investments, LLC is not affiliated with the companies listed above.</p>\n<p class=\"disclaimer\">Neither FTSE, LSEG, nor NAREIT makes any warranty regarding the FTSE Nareit Equity REITS Index, FTSE Nareit All Residential Capped Index or FTSE Nareit All Mortgage Capped Index. Neither FTSE, EPRA, LSEG, nor NAREIT makes any warranty regarding the FTSE EPRA Nareit Developed ex-U.S. Index, FTSE EPRA Nareit Developed Green Target Index or FTSE EPRA Nareit Global REITs Index. “FTSE®” is a trademark of London Stock Exchange Group companies and is used by FTSE under license.</p>"},{"metadata":null,"text":"<a name=\"esg-footer\"></a>\n<p class=\"disclaimer\">For funds with an investment objective that include the integration of ESG criteria, there may be corporate actions or other situations that may cause the fund or index to passively hold securities that may not comply with ESG criteria. Please refer to the fund’s prospectus for more information. The screening applied by the fund's index provider may include revenue thresholds set by the index provider. The information displayed on this website may not include all of the screens that apply to the relevant index or the relevant fund. These screens are described in more detail in the fund’s prospectus, other fund documents, and the relevant index methodology document.</p>\n<p class=\"disclaimer\">Review the MSCI methodology behind the Sustainability Characteristics and Business Involvement metrics: <a href=\"https://www.msci.com/esg-fund-ratings\" target=\"_blank\" rel=\"noopener\"><sup>1</sup>ESG Fund Ratings</a>; <a href=\"https://www.msci.com/index-carbon-footprint-metrics\" target=\"_blank\" rel=\"noopener\"><sup>2</sup>Index Carbon Footprint Metrics</a>; <a href=\"https://www.msci.com/documents/1296102/1636401/MSCI_ESG_BIS_Research_Productsheet_April+2015.pdf/babff66f-d1d6-4308-b63d-57fb7c5ccfa9\" target=\"_blank\" rel=\"noopener\"><sup>3</sup>Business Involvement Screening Research</a>; <a href=\"https://www.msci.com/indexes/documents/methodology/2_MSCI_Screened_Indexes_Methodology_20241230.pdf\" target=\"_blank\" rel=\"noopener\"><sup>4</sup>ESG Screened Index Methodology</a>; <a href=\"https://www.msci.com/documents/10199/acbe7c8a-a4e4-49de-9cf8-5e957245b86b\" target=\"_blank\" rel=\"noopener\"><sup>5</sup>ESG Controversies</a>; <a href=\"https://www.msci.com/documents/1296102/27422075/ImpliedTemperatureRise-cfs-en.pdf\" target=\"_blank\" rel=\"noopener\"><sup>6</sup>MSCI Implied Temperature Rise</a></p>\n<p class=\"disclaimer\">Certain information contained herein (the “Information”) has been provided by MSCI ESG Research LLC, a RIA under the Investment Advisers Act of 1940, and may include data from its affiliates (including MSCI Inc. and its subsidiaries (“MSCI”)), or third party suppliers (each an “Information Provider”), and it may not be reproduced or redisseminated in whole or in part without prior written permission. The Information has not been submitted to, nor received approval from, the US SEC or any other regulatory body. The Information may not be used to create any derivative works, or in connection with, nor does it constitute, an offer to buy or sell, or a promotion or recommendation of, any security, financial instrument or product or trading strategy, nor should it be taken as an indication or guarantee of any future performance, analysis, forecast or prediction. Some funds may be based on or linked to MSCI indexes, and MSCI may be compensated based on the fund’s assets under management or other measures. MSCI has established an information barrier between equity index research and certain Information. None of the Information in and of itself can be used to determine which securities to buy or sell or when to buy or sell them. The Information is provided “as is” and the user of the Information assumes the entire risk of any use it may make or permit to be made of the Information. Neither MSCI ESG Research nor any Information Party makes any representations or express or implied warranties (which are expressly disclaimed), nor shall they incur liability for any errors or omissions in the Information, or for any damages related thereto. The foregoing shall not exclude or limit any liability that may not by applicable law be excluded or limited.</p>"},{"metadata":null,"text":"<p class=\"disclaimer\">© 2026 BlackRock, Inc. <strong>BLACKROCK, BLACKROCK SOLUTIONS, BUILD ON BLACKROCK, ALADDIN, iSHARES, iBONDS, FACTORSELECT, iTHINKING, iSHARES CONNECT, FUND FRENZY, LIFEPATH, SO WHAT DO I DO WITH MY MONEY, INVESTING FOR A NEW WORLD, BUILT FOR THESE TIMES,</strong> the iShares Core Graphic,<strong> CoRI </strong>and the <strong>CoRI </strong>logo are trademarks of BlackRock, Inc., or its subsidiaries in the United States and elsewhere. All other marks are the property of their respective owners.</p>"},{"metadata":null,"text":"<div>T&amp;O0525-5345183-EXP0528</div>"},{"metadata":null,"text":"T&amp;O0525-5345183-EXP0528"}],"product-risks-title":[{"metadata":null,"text":"<div class=\"fund-component\">\n<h2 class=\"mobile-hidden\" data-link-target=\"\">Key Risks</h2></div>"}],"product_keyword":[{"metadata":null,"text":"health care, growth, small-cap, small cap, technolgoy, financial, stock etf, r2, r2000, russell 2, russell 2000"}],"product_structure.physical":[{"metadata":null,"text":"Physical"}],"product_structure.synthetic":[{"metadata":null,"text":"Synthetic"}],"red-oak-footer":[{"metadata":null,"text":"501848"}],"release-testing":[{"metadata":null,"text":"ROhit - fred.investorClassCode USD <br />Product Gross Return - fred.grossReturn After Cost - fred.longModerateFelBelAnn <br />Front Cost - fred.frontCostAmt Front Pct - fred.frontCostPercent Prospectus Name - fred.fundProspectusName <br />Short Name - fred.investorClassCode USD <br />ISin - US4642876555    RHP - <recommendedHoldingPeriod/>"}],"risk-indicator.disclaimer":[],"risk_profile.disclaimer":[{"metadata":null,"text":"Based on the 1 year standard deviation of the fund. Standard deviation measures how dispersed returns are around the average. A higher standard deviation indicates that returns are spread out over a larger range of values and thus, more volatile or risky. Each increment on the scale above represents a 5% range of standard deviation except for the last segment which is &gt;20%."}],"search-card.contacts":[],"search-card.positioning":[],"sec-lending.summary.disclaimer":[{"metadata":null,"text":"The above table summarises the lending data available for the fund.<br /><br />The information in the Lending Summary table will not be displayed for the funds that have participated in securities lending for less than 12 months. The figures shown relate to past performance. Past performance is not a reliable indication of current or future results.<br />BlackRock’s policy is to disclose performance information quarterly subject to a one-month delay. This means that returns from 01/01/2019 to 31/12/2019 can be publicly disclosed from 01/02/2020.<br /><br />Maximum on-loan figure may increase or decrease over time.<br /><br /><span>With securities lending there is a risk of loss should the borrower default before the securities are returned, and due to market movements, the value of collateral held has fallen and/or the value of the securities on loan has risen.</span>"}],"section-headers.cumulative-performance":[{"metadata":null,"text":"CUMULATIVE &amp; ANNUALISED PERFORMANCE"}],"section_headers.annual_performance":[{"metadata":null,"text":"CUMULATIVE &amp; ANNUALISED PERFORMANCE"}],"section_headers.asset_allocation_breakdown":[{"metadata":null,"text":"ASSET ALLOCATION (%)"}],"section_headers.asset_type_breakdown":[{"metadata":null,"text":"ASSET TYPE BREAKDOWN (%)"}],"section_headers.breakdown_of_fees_and_expenses":[{"metadata":null,"text":"FEES AND EXPENSES BREAKDOWN"}],"section_headers.country_breakdown":[{"metadata":null,"text":"GEOGRAPHIC BREAKDOWN (%)"}],"section_headers.country_long_short_breakdown":[{"metadata":null,"text":"Geographic Breakdown (%)<sup>2</sup>"}],"section_headers.credit_rating_longshort_breakdown":[{"metadata":null,"text":"CREDIT RATINGS (%)<sup>2 3</sup>"}],"section_headers.credit_ratings_breakdown":[{"metadata":null,"text":"CREDIT RATINGS (%)"}],"section_headers.currency_breakdown":[{"metadata":null,"text":"CURRENCY EXPOSURE (%)"}],"section_headers.custom_content":[{"metadata":null,"text":"Strategy and Investment Process"}],"section_headers.dealing_information":[{"metadata":null,"text":"DEALING INFORMATION"}],"section_headers.discrete_performance":[{"metadata":null,"text":"CALENDAR YEAR PERFORMANCE (% USD)"}],"section_headers.distribution_information":[{"metadata":null,"text":"FUND DISTRIBUTIONS"}],"section_headers.fund_characteristics":[{"metadata":null,"text":"FUND CHARACTERISTICS"}],"section_headers.fund_details":[{"metadata":null,"text":"Key Facts"}],"section_headers.fund_performance":[{"metadata":null,"text":"Performance"}],"section_headers.fund_specific_risks":[{"metadata":null,"text":"<strong>KEY RISKS: </strong>"}],"section_headers.glossary":[{"metadata":null,"text":"GLOSSARY"}],"section_headers.management_expense_ratio":[{"metadata":null,"text":"<b>Management Expense Ratio</b>"}],"section_headers.market_cap_long_short":[{"metadata":null,"text":"MARKET CAPITALIZATION (%)<sup>2</sup>"}],"section_headers.maturity_breakdown":[{"metadata":null,"text":"MATURITY BREAKDOWN (%)"}],"section_headers.maturity_long_short_breakdown":[{"metadata":null,"text":"MATURITY BREAKDOWN"}],"section_headers.money_market_bond_type_breakdown":[{"metadata":null,"text":"Bond Type Breakdown"}],"section_headers.portfolio_characteristics":[{"metadata":null,"text":"Portfolio Characteristics"}],"section_headers.portfolio_management":[{"metadata":null,"text":"PORTFOLIO MANAGEMENT"}],"section_headers.preferred_credit_rating":[{"metadata":null,"text":"Preferred Ratings Summary"}],"section_headers.ratings":[{"metadata":null,"text":"Ratings<sup>**</sup>"}],"section_headers.region_breakdown":[{"metadata":null,"text":"REGIONAL EXPOSURE (%)"}],"section_headers.region_long_short_breakdown":[{"metadata":null,"text":"TOP COUNTRIES (%)<sup>2</sup>"}],"section_headers.related_funds":[{"metadata":null,"text":"Related Funds"}],"section_headers.sector_breakdown":[{"metadata":null,"text":"TOP SECTORS (%)<sup>2</sup>"}],"section_headers.sector_level_summary":[{"metadata":null,"text":"Sector Level Summary"}],"section_headers.sector_long_short_breakdown":[{"metadata":null,"text":"SECTOR BREAKDOWN (%)<sup>2</sup>"}],"section_headers.talking_points":[{"metadata":null,"text":"WHY IWM?"}],"section_headers.top_3_maturity_bucket_holding":[{"metadata":null,"text":"Top 3 Holdings by Maturity Bucket"}],"section_headers.top_5_maturity_bucket_holding":[{"metadata":null,"text":"Top 5 Holdings by Maturity Bucket"}],"section_headers.top_corporate_government_bonds":[{"metadata":null,"text":"Top 5 Corporate/Top 5 Government Holdings"}],"section_headers.top_holdings":[{"metadata":null,"text":"Top Holdings (%)"}],"section_headers.top_issuers":[{"metadata":null,"text":"TOP ISSUERS"}],"section_headers.top_look_thru_holdings":[{"metadata":null,"text":"TOP UNDERLYING HOLDINGS (%)"}],"section_headers.trading_information":[{"metadata":null,"text":"TRADING INFORMATION"}],"section_headers.want_to_learn_more":[{"metadata":null,"text":"Want to learn more?"}],"sfdr-art-8":[{"metadata":null,"text":"<p class=\"disclaimer\">BlackRock Portfolio Managers have access to research, data, tools, and analytics to integrate ESG insights into their investment process. Aladdin is the operating system that connects the data, people and technology necessary to manage portfolios in real time, as well as the engine behind BlackRock’s ESG analytics and reporting capabilities. BlackRock’s Portfolio Managers use Aladdin to make investment decisions, monitor portfolios and to access material ESG insights that can inform the investment process to attain ESG characteristics of the fund.</p>\n<p class=\"disclaimer\">ESG datasets are sourced from external third-party data providers, including but not limited to MSCI and Sustainalytics. These datasets include headline ESG scores, carbon data, business involvement metrics or controversies and have been incorporated into Aladdin tools that are available to Portfolio Managers. Such tools support the full investment process, from research, to portfolio construction and modeling, to reporting.</p>\n<p class=\"disclaimer\">In addition to having access to these datasets in Aladdin, where applicable, Portfolio Managers could also supplement these sources with sell side research, non-government organization reports, company reported data, fundamental research insights prepared by BlackRock equity and credit investment research teams.</p>\n<p class=\"disclaimer\">In order to offer scalable solutions to investors across different asset classes and investment styles, BlackRock has developed a set of exclusionary screens, “BlackRock EMEA Baseline Screens”, that seeks to address a majority of our clients’ requests for exclusions.</p>\n<p class=\"disclaimer\">As an example, these exclusionary screens eliminate holdings with more than de minimis exposure to certain sectors/industries including but not limited to controversial weapons, nuclear weapons, fossil fuels, civilian firearms, tobacco, and UN Global Compact violators. BlackRock EMEA Baseline Screens are applied on all new active funds in Europe, Middle East and Africa (“EMEA”), on a comply or explain basis by our portfolio management teams within our product governance structure. For all new sustainable index strategies in EMEA, BlackRock works with the index provider to reflect the same screens in the custom index. Qualified investors with separate accounts can have exclusionary screens set with specific criteria as determined by the investor. The definition of the baseline screens and its adoption into sustainable screened funds is governed by the Sustainable Product Council (“SPC”). The current default ESG data provider for these Baseline Screens is MSCI but investment teams can choose to use Sustainalytics or other custom data sources as required.</p>\n<p class=\"disclaimer\">For further SFDR related fund/sub-fund level disclosures, please refer to the fund/ sub-fund specific Investment Objective and Policy section(s) and benchmark information in the prospectus that is available on the website.</p>"}],"sfdr-art-9":[{"metadata":null,"text":"<p class=\"disclaimer\">BlackRock Portfolio Managers have access to research, data, tools, and analytics to integrate ESG insights into their investment process. Aladdin is the operating system that connects the data, people and technology necessary to manage portfolios in real time, as well as the engine behind BlackRock’s ESG analytics and reporting capabilities. BlackRock’s Portfolio Managers use Aladdin to make investment decisions, monitor portfolios and to access material ESG insights that can inform the investment process to attain ESG characteristics of the fund.</p>\n<p class=\"disclaimer\">ESG datasets are sourced from external third-party data providers, including but not limited to MSCI and Sustainalytics. These datasets include headline ESG scores, carbon data, business involvement metrics or controversies and have been incorporated into Aladdin tools that are available to Portfolio Managers. Such tools support the full investment process, from research, to portfolio construction and modeling, to reporting.</p>\n<p class=\"disclaimer\">In addition to having access to these datasets in Aladdin, where applicable, Portfolio Managers could also supplement these sources with sell side research, non-government organization reports, company reported data, fundamental research insights prepared by BlackRock equity and credit investment research teams as well as the BlackRock Investment Stewardship team.</p>\n<p class=\"disclaimer\">For further SFDR related fund/sub-fund level disclosures, please refer to the fund/ sub-fund specific Investment Objective and Policy section(s) and benchmark information in the prospectus that is available on the website.</p>"}],"sfdr2.subtitle":[{"metadata":null,"text":"This section provides sustainability-related information about the Fund, pursuant to Article 10 SFDR."}],"strategy-char.bottom-disclaimer":[{"metadata":null,"text":"<p><span class=\"emphasis\">The Fund’s position relative to the Cap and Buffer should be considered before investing in the Fund. Investors may experience different outcomes if Fund shares are not held for the entire Hedge Period.</span><br /><br /><br /></p>\n<p class=\"emphasis\">What is the Hedge Period and how can it affect investor experience?</p>\n<p>The Buffer and Cap apply to Fund shares held over the entire Hedge Period. An investor that purchases Fund shares after the beginning of a Hedge Period, or sells Fund shares before the end of a Hedge Period, may not fully realize the Buffer or Cap for the Hedge Period and may be exposed to greater risk of loss. For example, if an investor purchases Fund shares during a Hedge Period at a time when the Underlying ETF’s share price has decreased from its price at the beginning of the Hedge Period, the investor’s Buffer may be decreased. Conversely, if an investor purchases Fund shares during a Hedge Period at a time when the Underlying ETF’s share price has increased from its price at the beginning of the Hedge Period, the investor’s upside potential may be reduced and the investor may experience losses prior to reaching the downside protection offered by the Buffer. Investors who sell prior to the end of the Hedge Period may not fully realize the Buffer or Cap.</p>"}],"strategy-char.disclaimer":[{"metadata":null,"text":"Strategy Characteristics are meant to provide investors with additional metrics on the options strategy used by the Fund. They are provided for transparency and illustrative purposes only, are not representative of a specific investment outcome and may not represent current value. The Cap and Buffer may vary from what is shown in the table above. All payoff figures, including the Buffer and Cap, are in reference to holding the Fund shares through the end of the Hedge Period and are not guaranteed. All figures shown are net of fees (as applicable)."}],"strategy-char.upper-disclaimer":[{"metadata":null,"text":"The Fund employs an options strategy that seeks to track the price return of the iShares Core S&amp;P 500 ETF (“the Underlying ETF” or the “Reference Asset”) while providing an approximate downside buffer (the “Buffer”) in exchange for an approximate cap (the “Cap”) on upside potential. The Buffer may help reduce volatility and mitigate the effects of a decline in the value of the Fund to a set range of potential losses for investors who hold Fund shares over the entire Hedge Period. The table below provides an indication of the Buffer and Cap levels as of the previous day’s market close."}],"us-prospectus-offer.disclaimer":[{"metadata":null,"text":"<strong>You should consider the investment objectives, risks, charges and expenses of the fund carefully before investing. The prospectus and, if available, the summary prospectus contain this and other information about the fund and are available, along with information on other BlackRock funds, by calling 800-882-0052 or from your financial professional. The prospectus should be read carefully before investing. Investing involves risks including possible loss of principal.</strong>"}]},"context":{"productId":"239710","portfolioType":"ISHARES_FUND_DATA","currencyCode":"USD","shareClass":"US Class","aladdinFundTicker":"I-R2000","ticker":"IWM","appSubType":"ISHARES","locale":"en_US","targetSite":"us-ishares","userType":"individual","productPageVersion":"2026.7.9","host":"https://varnish-frontend-live.cwp.svc.cluster.local:6081"},"services":{"apiHost":"https://www.blackrock.com/varnish-api/blk-one01-product-data/product-data/api/v2/get-product-data?","marketingServiceUrl":"https://www.blackrock.com/varnish-api/marketing-service"}}"></walrus-context><div><div><div class="_ws-col-12"><div><div><div class="_ws-row"><div class="_ws-col-12"><div data-componentname="DisplayControlledParagraphV3"><walrus-render-on-client componenttype="on-server-first" componentprops="{"componentId":"displayControlledParagraph","componentProps":{"componentType":"DisplayControlledParagraphV3","fragmentCodes":"nothing_to_display","enableTopPadding":true,"enableBottomPadding":true},"containersByNameMap":{"default":{"visible":true,"properties":{},"dataPointsByNameMap":{"esg-analytics.standalone-subtitle-nsfl":{"visible":true,"name":"esg-analytics.standalone-subtitle-nsfl","sortOrder":21,"formattedValue":"-"}}}}}" componentkey="DisplayControlledParagraphV3"><div webqc-datapoint="displayControlledParagraph" class="_ws-fund-component _ws-fund-component-container _ws-v3 _ws-full-bleed _ws-padding-fluid-s" data-id="displayControlledParagraph-container" data-componentname="displayControlledParagraph" role="region" aria-labelledby="displayControlledParagraph-header" tabindex="-1"><div class="_ws-container-fluid"></div></div></walrus-render-on-client></div><div data-componentname="FundParagraphV3"><walrus-render-on-client componenttype="on-server-first" componentprops="{"componentProps":{"componentType":"FundParagraphV3","fragmentCodes":"product-page.footer.disclaimer","enableTopPadding":true,"enableBottomPadding":true}}" componentkey="FundParagraphV3"><div webqc-datapoint="fundParagraphV3" class="_ws-fund-component _ws-fund-component-container _ws-v3 _ws-full-bleed" data-id="fundParagraphV3-container" data-componentname="fundParagraphV3" role="region" aria-labelledby="fundParagraphV3-header" tabindex="-1"><div class="_ws-container-fluid"><div class="" data-disclaimer-fragment="product-page.footer.disclaimer"><div class="_ws-_disclaimerText_x5rod_25"><div class="_ws-_disclaimerTextParagraphContainer_x5rod_28"><p class="_ws-oneds-body-s"><strong>Carefully consider the Funds' investment objectives, risk factors, and charges and expenses before investing. This and other information can be found in the Funds' prospectuses or, if available, the summary prospectuses, which may be obtained by visiting the <a href="https://www.blackrock.com/us/individual/resources/regulatory-documents#etfs" target="_blank" rel="noopener">iShares Fund</a> and <a href="https://www.blackrock.com/us/individual/resources/regulatory-documents#mutualfunds" target="_blank" title="BlackRock Fund" rel="noopener">BlackRock Fund</a> prospectus pages. Read the prospectus carefully before investing.</strong><br /></p></div></div></div><div class="_ws-_fundParagraphDisc_x5rod_32" data-disclaimer-fragment="product-page.footer.disclaimer"><div class="_ws-_disclaimerText_x5rod_25"><div class="_ws-_disclaimerTextParagraphContainer_x5rod_28"><p class="_ws-oneds-body-s"><span style="font-size:15px"><strong>Investing involves risk, including possible loss of principal.</strong></span></p></div></div></div><div class="_ws-_fundParagraphDisc_x5rod_32" data-disclaimer-fragment="product-page.footer.disclaimer"><div class="_ws-_disclaimerText_x5rod_25"><div class="_ws-_disclaimerTextParagraphContainer_x5rod_28"><p class="_ws-oneds-body-s">If the Fund invests in any underlying fund, certain portfolio information, including sustainability characteristics and business-involvement metrics, provided for the Fund may include information (on a look-through basis) of such underlying fund, to the extent available.</p></div></div></div><div class="_ws-_fundParagraphDisc_x5rod_32" data-disclaimer-fragment="product-page.footer.disclaimer"><div class="_ws-_disclaimerText_x5rod_25"><div class="_ws-_disclaimerTextParagraphContainer_x5rod_28"><p class="_ws-oneds-body-s">Small-capitalization companies may be less stable and more susceptible to adverse developments, and their securities may be more volatile and less liquid than larger capitalization companies.</p></div></div></div><div class="_ws-_fundParagraphDisc_x5rod_32" data-disclaimer-fragment="product-page.footer.disclaimer"><div class="_ws-_disclaimerText_x5rod_25"><div class="_ws-_disclaimerTextParagraphContainer_x5rod_28"><p class="_ws-oneds-body-s">Shares of ETFs are bought and sold at market price (not NAV) and are not individually redeemed from the fund. Any applicable brokerage commissions will reduce returns. Beginning August 10, 2020, market price returns for BlackRock and iShares ETFs are calculated using the closing price and account for distributions from the fund. Prior to August 10, 2020, market price returns for BlackRock and iShares ETFs were calculated using the midpoint price and accounted for distributions from the fund. The midpoint is the average of the bid/ask prices at 4:00 PM ET (when NAV is normally determined for most ETFs). The returns shown do not represent the returns you would receive if you traded shares at other times.</p></div></div></div><div class="_ws-_fundParagraphDisc_x5rod_32" data-disclaimer-fragment="product-page.footer.disclaimer"><div class="_ws-_disclaimerText_x5rod_25"><div class="_ws-_disclaimerTextParagraphContainer_x5rod_28"><p class="_ws-oneds-body-s"><strong>Index returns are for illustrative purposes only. Index performance returns do not reflect any management fees or expenses. Indexes are unmanaged and one cannot invest directly in an index. Past performance does not guarantee future results.</strong></p></div></div></div><div class="_ws-_fundParagraphDisc_x5rod_32" data-disclaimer-fragment="product-page.footer.disclaimer"><div class="_ws-_disclaimerText_x5rod_25"><div class="_ws-_disclaimerTextParagraphContainer_x5rod_28"><p class="_ws-oneds-body-s">After-tax returns are calculated using the historical highest individual federal marginal income tax rates and do not reflect the impact of state and local taxes. Actual after-tax returns depend on the investor's tax situation and may differ from those shown. The after-tax returns shown are not relevant to investors who hold their fund shares through tax-deferred arrangements such as 401(k) plans or individual retirement accounts.</p></div></div></div><div class="_ws-_fundParagraphDisc_x5rod_32" data-disclaimer-fragment="product-page.footer.disclaimer"><div class="_ws-_disclaimerText_x5rod_25"><div class="_ws-_disclaimerTextParagraphContainer_x5rod_28"><p class="_ws-oneds-body-s">Certain sectors and markets perform exceptionally well based on current market conditions and iShares and BlackRock Funds can benefit from that performance. Achieving such exceptional returns involves the risk of volatility and investors should not expect that such results will be repeated.</p></div></div></div><div class="_ws-_fundParagraphDisc_x5rod_32" data-disclaimer-fragment="product-page.footer.disclaimer"><div class="_ws-_disclaimerText_x5rod_25"><div class="_ws-_disclaimerTextParagraphContainer_x5rod_28"><p class="_ws-oneds-body-s">Distribution Yield and 12m Trailing Yield results may have period over period volatility due to factors including tax considerations such as treatment of passive foreign investment companies (PFICs), treatment of defaulted bonds or excise tax requirements; exceptional corporate actions; seasonality of dividends from underlying holdings; significant fluctuations in fund shares outstanding; or fund capital gain distributions.</p></div></div></div><div class="_ws-_fundParagraphDisc_x5rod_32" data-disclaimer-fragment="product-page.footer.disclaimer"><div class="_ws-_disclaimerText_x5rod_25"><div class="_ws-_disclaimerTextParagraphContainer_x5rod_28"><p class="_ws-oneds-body-s">The Funds are distributed by BlackRock Investments, LLC (together with its affiliates, “BlackRock”).</p></div></div></div><div class="_ws-_fundParagraphDisc_x5rod_32" data-disclaimer-fragment="product-page.footer.disclaimer"><div class="_ws-_disclaimerText_x5rod_25"><div class="_ws-_disclaimerTextParagraphContainer_x5rod_28"><p class="_ws-oneds-body-s">Although BlackRock shall obtain data from sources that BlackRock considers reliable, all data contained herein is provided “as is” and BlackRock makes no representation or warranty of any kind, either express or implied, with respect to such data, the timeliness thereof, the results to be obtained by the use thereof or any other matter. BlackRock expressly disclaims any and all implied warranties, including without limitation, warranties of originality, accuracy, completeness, timeliness, non-infringement, merchantability and fitness for a particular purpose.</p></div></div></div><div class="_ws-_fundParagraphDisc_x5rod_32" data-disclaimer-fragment="product-page.footer.disclaimer"><div class="_ws-_disclaimerText_x5rod_25"><div class="_ws-_disclaimerTextParagraphContainer_x5rod_28"><p class="_ws-oneds-body-s">BlackRock provides compensation in connection with obtaining or using third-party ratings and rankings.</p></div></div></div><div class="_ws-_fundParagraphDisc_x5rod_32" data-disclaimer-fragment="product-page.footer.disclaimer"><div class="_ws-_disclaimerText_x5rod_25"><div class="_ws-_disclaimerTextParagraphContainer_x5rod_28"><p class="_ws-oneds-body-s">The iShares Funds are not sponsored, endorsed, issued, sold or promoted by Bloomberg, BlackRock Index Services, LLC, Cboe Global Indices, LLC, Cohen & Steers, European Public Real Estate Association (“EPRA® ”), FTSE International Limited (“FTSE”), ICE Data Indices, LLC, NSE Indices Ltd, JPMorgan, JPX Group, London Stock Exchange Group (“LSEG”), MSCI Inc., Markit Indices Limited, Morningstar, Inc., Nasdaq, Inc., National Association of Real Estate Investment Trusts (“NAREIT”), Nikkei, Inc., Russell, S&P Dow Jones Indices LLC or STOXX Ltd. None of these companies make any representation regarding the advisability of investing in the Funds. With the exception of BlackRock Index Services, LLC, who is an affiliate, BlackRock Investments, LLC is not affiliated with the companies listed above.</p><p class="_ws-oneds-body-s">Neither FTSE, LSEG, nor NAREIT makes any warranty regarding the FTSE Nareit Equity REITS Index, FTSE Nareit All Residential Capped Index or FTSE Nareit All Mortgage Capped Index. Neither FTSE, EPRA, LSEG, nor NAREIT makes any warranty regarding the FTSE EPRA Nareit Developed ex-U.S. Index, FTSE EPRA Nareit Developed Green Target Index or FTSE EPRA Nareit Global REITs Index. “FTSE®” is a trademark of London Stock Exchange Group companies and is used by FTSE under license.</p></div></div></div><div class="_ws-_fundParagraphDisc_x5rod_32" data-disclaimer-fragment="product-page.footer.disclaimer"><div class="_ws-_disclaimerText_x5rod_25"><div class="_ws-_disclaimerTextParagraphContainer_x5rod_28"><p class="_ws-oneds-body-s"><a name="esg-footer"></a></p><p class="_ws-oneds-body-s">For funds with an investment objective that include the integration of ESG criteria, there may be corporate actions or other situations that may cause the fund or index to passively hold securities that may not comply with ESG criteria. Please refer to the fund’s prospectus for more information. The screening applied by the fund's index provider may include revenue thresholds set by the index provider. The information displayed on this website may not include all of the screens that apply to the relevant index or the relevant fund. These screens are described in more detail in the fund’s prospectus, other fund documents, and the relevant index methodology document.</p><p class="_ws-oneds-body-s">Review the MSCI methodology behind the Sustainability Characteristics and Business Involvement metrics: <a href="https://www.msci.com/esg-fund-ratings" target="_blank" rel="noopener"><sup>1</sup>ESG Fund Ratings</a>; <a href="https://www.msci.com/index-carbon-footprint-metrics" target="_blank" rel="noopener"><sup>2</sup>Index Carbon Footprint Metrics</a>; <a href="https://www.msci.com/documents/1296102/1636401/MSCI_ESG_BIS_Research_Productsheet_April+2015.pdf/babff66f-d1d6-4308-b63d-57fb7c5ccfa9" target="_blank" rel="noopener"><sup>3</sup>Business Involvement Screening Research</a>; <a href="https://www.msci.com/indexes/documents/methodology/2_MSCI_Screened_Indexes_Methodology_20241230.pdf" target="_blank" rel="noopener"><sup>4</sup>ESG Screened Index Methodology</a>; <a href="https://www.msci.com/documents/10199/acbe7c8a-a4e4-49de-9cf8-5e957245b86b" target="_blank" rel="noopener"><sup>5</sup>ESG Controversies</a>; <a href="https://www.msci.com/documents/1296102/27422075/ImpliedTemperatureRise-cfs-en.pdf" target="_blank" rel="noopener"><sup>6</sup>MSCI Implied Temperature Rise</a></p><p class="_ws-oneds-body-s">Certain information contained herein (the “Information”) has been provided by MSCI ESG Research LLC, a RIA under the Investment Advisers Act of 1940, and may include data from its affiliates (including MSCI Inc. and its subsidiaries (“MSCI”)), or third party suppliers (each an “Information Provider”), and it may not be reproduced or redisseminated in whole or in part without prior written permission. The Information has not been submitted to, nor received approval from, the US SEC or any other regulatory body. The Information may not be used to create any derivative works, or in connection with, nor does it constitute, an offer to buy or sell, or a promotion or recommendation of, any security, financial instrument or product or trading strategy, nor should it be taken as an indication or guarantee of any future performance, analysis, forecast or prediction. Some funds may be based on or linked to MSCI indexes, and MSCI may be compensated based on the fund’s assets under management or other measures. MSCI has established an information barrier between equity index research and certain Information. None of the Information in and of itself can be used to determine which securities to buy or sell or when to buy or sell them. The Information is provided “as is” and the user of the Information assumes the entire risk of any use it may make or permit to be made of the Information. Neither MSCI ESG Research nor any Information Party makes any representations or express or implied warranties (which are expressly disclaimed), nor shall they incur liability for any errors or omissions in the Information, or for any damages related thereto. The foregoing shall not exclude or limit any liability that may not by applicable law be excluded or limited.</p></div></div></div><div class="_ws-_fundParagraphDisc_x5rod_32" data-disclaimer-fragment="product-page.footer.disclaimer"><div class="_ws-_disclaimerText_x5rod_25"><div class="_ws-_disclaimerTextParagraphContainer_x5rod_28"><p class="_ws-oneds-body-s">© 2026 BlackRock, Inc. <strong>BLACKROCK, BLACKROCK SOLUTIONS, BUILD ON BLACKROCK, ALADDIN, iSHARES, iBONDS, FACTORSELECT, iTHINKING, iSHARES CONNECT, FUND FRENZY, LIFEPATH, SO WHAT DO I DO WITH MY MONEY, INVESTING FOR A NEW WORLD, BUILT FOR THESE TIMES,</strong> the iShares Core Graphic,<strong> CoRI </strong>and the <strong>CoRI </strong>logo are trademarks of BlackRock, Inc., or its subsidiaries in the United States and elsewhere. All other marks are the property of their respective owners.</p></div></div></div><div class="_ws-_fundParagraphDisc_x5rod_32" data-disclaimer-fragment="product-page.footer.disclaimer"><div class="_ws-_disclaimerText_x5rod_25"><div class="_ws-_disclaimerTextParagraphContainer_x5rod_28"><p class="_ws-oneds-body-s"><div>T&O0525-5345183-EXP0528</div></p></div></div></div><div class="_ws-_fundParagraphDisc_x5rod_32"